.game-page {
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #0f1923 0%, #143028 45%, #1b5e3b 100%);
  overflow: hidden;
}

.table {
  flex: 1;
  min-height: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 4rpx 8rpx 0;
}

.table-top {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
}

.player-dock {
  flex-shrink: 0;
  padding-bottom: 4rpx;
  overflow: visible;
  background: linear-gradient(180deg, rgba(15, 25, 35, 0) 0%, rgba(15, 25, 35, 0.55) 28%, rgba(15, 25, 35, 0.72) 100%);
}

.overlay {
  position: absolute;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 24rpx;
}
