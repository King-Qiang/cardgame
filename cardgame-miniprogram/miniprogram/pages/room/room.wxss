.room-page {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  background: var(--bg-app);
  box-sizing: border-box;
  padding: var(--safe-top) var(--safe-right) var(--safe-bottom) var(--safe-left);
  gap: 24rpx;
}

.room-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.room-id-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.room-id {
  font-size: 28rpx;
  font-weight: 600;
}

.mini-btn {
  font-size: 20rpx !important;
  padding: 8rpx 16rpx !important;
  line-height: 1.2 !important;
}

.leave-btn {
  font-size: 24rpx !important;
  padding: 12rpx 24rpx !important;
}

.seats {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.seat {
  width: 220rpx;
  min-height: 260rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
}

.seat.empty {
  opacity: 0.65;
  border-style: dashed;
}

.seat-label {
  font-size: 20rpx;
  color: var(--text-3);
}

.seat-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: var(--bg-panel-hover);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.seat-name-row {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.seat-name {
  font-size: 24rpx;
  max-width: 160rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.owner-badge {
  font-size: 22rpx;
}

.robot-badge {
  font-size: 18rpx;
  color: #60a5fa;
  padding: 2rpx 8rpx;
  border: 1rpx solid rgba(96, 165, 250, 0.4);
  border-radius: 999rpx;
}

.remove-bot-btn {
  margin-top: 4rpx;
}

.ready-tag {
  font-size: 20rpx;
  color: var(--success);
}

.ready-tag.pending {
  color: var(--text-3);
}

.room-actions {
  display: flex;
  justify-content: center;
  gap: 20rpx;
}

.action-btn {
  min-width: 220rpx;
}

.start-btn[disabled] {
  opacity: 0.45;
}

.leave-hint {
  display: block;
  text-align: center;
  color: var(--text-2);
  font-size: 26rpx;
}
