.shop-body {
  flex: 1;
  min-height: 0;
  align-items: stretch !important;
  justify-content: flex-start !important;
  padding: 6rpx 0 8rpx;
  overflow: hidden;
}

.top-actions {
  margin-right: 4rpx;
}

.mini-btn {
  padding: 4rpx 10rpx !important;
  font-size: 18rpx !important;
  line-height: 1.2 !important;
}

/* 高度随 sub-body 剩余空间伸缩，避免写死 340rpx 在矮屏横屏下裁切底部 */
.shop-scroll {
  width: 100%;
  flex: 1;
  min-height: 0;
}

.shop-row {
  display: inline-flex;
  flex-direction: row;
  align-items: stretch;
  gap: 12rpx;
  height: 100%;
  min-height: 100%;
  padding: 6rpx 32rpx 14rpx 12rpx;
  box-sizing: border-box;
}

.shop-card {
  width: 210rpx;
  height: 100%;
  min-height: 0;
  padding: 12rpx 12rpx 14rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex-shrink: 0;
  overflow: visible;
}

.shop-card .name {
  flex-shrink: 0;
  font-size: 20rpx;
  font-weight: 600;
  line-height: 1.25;
}

.shop-card .grant {
  flex: 1;
  min-height: 0;
  font-size: 18rpx;
  color: var(--gold);
  display: flex;
  align-items: center;
}

.shop-card .price {
  flex-shrink: 0;
  font-size: 18rpx;
  color: var(--text-2);
}

.buy-btn {
  flex-shrink: 0;
  width: 100%;
  margin-top: 4rpx;
  padding: 6rpx 0 !important;
  font-size: 18rpx !important;
  line-height: 1.3 !important;
}

.modal-text {
  font-size: 22rpx;
  color: var(--text-2);
  white-space: pre-line;
  line-height: 1.5;
}
