.season-tag {
  font-size: 18rpx;
  color: var(--text-3);
  margin-right: 8rpx;
}

.rank-tabs {
  display: flex;
  gap: 8rpx;
  padding: 0 12rpx 8rpx;
  flex-shrink: 0;
}

.rank-tabs .tab {
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  background: var(--bg-panel);
  font-size: 20rpx;
  color: var(--text-2);
}

.rank-tabs .tab.active {
  background: var(--accent);
  color: #fff;
}

.rank-tabs .tab.disabled {
  opacity: 0.5;
}

.rank-body {
  flex: 1;
  min-height: 0;
  display: flex;
  gap: 12rpx;
  padding: 0 12rpx 12rpx;
}

.my-card {
  width: 360rpx;
  flex-shrink: 0;
  padding: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.card-title {
  font-size: 20rpx;
  color: var(--text-2);
}

.my-card .tier {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--gold);
}

.progress {
  font-size: 18rpx;
  color: var(--text-3);
  line-height: 1.4;
}

.board {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  padding: 8rpx 0;
}

.board-head,
.board-row {
  display: flex;
  align-items: center;
  padding: 8rpx 12rpx;
  font-size: 20rpx;
}

.board-head {
  color: var(--text-2);
  font-weight: 600;
  flex-shrink: 0;
}

.board-list {
  flex: 1;
  min-height: 0;
}

.board-row {
  border-bottom: 1rpx solid var(--border);
}

.col.rank {
  width: 12%;
}

.col.name {
  width: 32%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.col.tier {
  width: 18%;
}

.col.pts {
  width: 18%;
}

.col.wl {
  width: 20%;
  text-align: right;
}

.rank-page {
  overflow: hidden;
}

.rank-page .rank-body {
  flex: 1;
  min-height: 0;
}
