<page-meta root-font-size="{{rootFontSize}}" page-style="{{viewportPageStyle}}" />
<landscape-shell activeTab="records">
  <view class="page">
    <view class="header">
      <text class="title">战绩记录</text>
    </view>
    <view wx:if="{{loading}}" class="hint panel">加载中…</view>
    <view wx:elif="{{empty}}" class="empty panel">
      <text class="empty-title">暂无对局记录</text>
      <text class="empty-desc">先去大厅开一局吧</text>
      <button class="btn-primary" bindtap="goLobby">去大厅</button>
    </view>
    <scroll-view wx:else class="list" scroll-y enhanced show-scrollbar="{{false}}">
      <view
        wx:for="{{rows}}"
        wx:key="recordId"
        class="row panel"
        data-id="{{item.recordId}}"
        bindtap="onRowTap"
      >
        <text class="col id">{{item.shortId}}</text>
        <text class="col game">{{item.gameTypeText}}</text>
        <text class="col mode">{{item.modeText}}</text>
        <text class="col result {{item.isWin ? 'win' : 'lose'}}">{{item.resultText}}</text>
        <text class="col gold {{item.myGoldDelta >= 0 ? 'pos' : 'neg'}}">{{item.goldText}}</text>
        <text class="col time">{{item.timeText}}</text>
        <text class="arrow">›</text>
      </view>
    </scroll-view>
  </view>
</landscape-shell>
