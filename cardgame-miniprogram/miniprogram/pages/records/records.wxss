.page {
  flex: 1;
  min-height: 0;
  height: 100%;
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.header {
  margin-bottom: var(--gap-md);
  flex-shrink: 0;
}

.title {
  font-size: 24rpx;
  font-weight: 600;
}

.hint {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  color: var(--text-2);
}

.empty {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--gap-sm);
  padding: 24rpx;
}

.empty-title {
  font-size: 22rpx;
}

.empty-desc {
  font-size: 18rpx;
  color: var(--text-2);
  text-align: center;
}

.list {
  flex: 1;
  min-height: 0;
}

.row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: var(--gap-sm);
  font-size: 18rpx;
}

.col.id {
  width: 120rpx;
  flex-shrink: 0;
  color: var(--text-2);
}

.col.game {
  width: 72rpx;
  flex-shrink: 0;
}

.col.mode {
  width: 56rpx;
  flex-shrink: 0;
  color: var(--text-2);
}

.col.result {
  width: 48rpx;
  flex-shrink: 0;
}

.col.result.win {
  color: #6bcb77;
}

.col.result.lose {
  color: #ff8a80;
}

.col.gold {
  width: 88rpx;
  flex-shrink: 0;
  text-align: right;
}

.col.gold.pos {
  color: #6bcb77;
}

.col.gold.neg {
  color: #ff8a80;
}

.col.time {
  flex: 1;
  text-align: right;
  color: var(--text-2);
}

.arrow {
  color: var(--text-2);
  flex-shrink: 0;
}
