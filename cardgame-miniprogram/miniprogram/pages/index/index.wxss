.page {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  padding: var(--safe-top) var(--safe-right) var(--safe-bottom) var(--safe-left);
  background: linear-gradient(135deg, #0f1923 0%, #1a2634 100%);
}

.center {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 24rpx;
}

.logo {
  font-size: 80rpx;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
}

.status {
  font-size: 24rpx;
  color: var(--text-2);
}

.retry {
  margin-top: 24rpx;
}
