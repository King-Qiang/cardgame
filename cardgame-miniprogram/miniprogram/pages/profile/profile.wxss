.page {
  flex: 1;
  min-height: 0;
  height: 100%;
  display: flex;
  flex-direction: column;
  gap: var(--gap-md);
  overflow-y: auto;
}

.header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 14rpx 18rpx;
  flex-shrink: 0;
}

.avatar {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  background: var(--bg-panel-hover);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  flex-shrink: 0;
}

.info {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex-shrink: 0;
}

.nickname {
  font-size: 26rpx;
  font-weight: 600;
}

.uid {
  font-size: 20rpx;
  color: var(--text-2);
}

.rank-block {
  margin-left: auto;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 4rpx;
  min-width: 0;
}

.rank-line {
  font-size: 22rpx;
}

.rank-sub {
  font-size: 20rpx;
  color: var(--text-2);
}

.grid {
  display: flex;
  gap: var(--gap-md);
  flex-shrink: 0;
}

.grid-item {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.links {
  padding: 12rpx 18rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  font-size: 22rpx;
  color: var(--text-2);
  flex-shrink: 0;
}

.logout {
  color: var(--danger);
  margin-left: auto;
}
