.result-page {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  background: var(--bg-app);
}

.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  min-width: 220rpx;
}

.hero.win .title {
  color: var(--gold);
}

.hero.lose .title {
  color: var(--text-2);
}

.emoji {
  font-size: 64rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
}

.stats {
  min-width: 360rpx;
  padding: 16rpx 20rpx;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 22rpx;
}

.label {
  color: var(--text-2);
}

.value {
  font-weight: 600;
}

.value.pos {
  color: var(--success);
}

.value.neg {
  color: var(--danger);
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  min-width: 180rpx;
}

.actions button {
  width: 100%;
}
