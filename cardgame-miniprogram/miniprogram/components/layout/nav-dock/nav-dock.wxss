.dock {
  width: 64rpx;
  height: 100%;
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 36rpx;
  background: rgba(0, 0, 0, 0.2);
  border-right: 1rpx solid var(--border);
}

.dock-item {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  position: relative;
}

.dock-item.active {
  background: var(--bg-panel-hover);
}

.dock-item.active::before {
  content: '';
  position: absolute;
  left: -8rpx;
  top: 8rpx;
  bottom: 8rpx;
  width: 4rpx;
  background: var(--gold);
  border-radius: 2rpx;
}

.icon {
  font-size: 26rpx;
}
