.shell {
  display: flex;
  flex-direction: row;
  width: 100%;
  height: 100%;
  box-sizing: border-box;
  padding: var(--safe-top) var(--safe-right) var(--safe-bottom) var(--safe-left);
  background: var(--bg-app);
  overflow: hidden;
}

.main {
  flex: 1;
  min-width: 0;
  min-height: 0;
  height: 100%;
  padding: 16rpx 20rpx 16rpx 12rpx;
  overflow: hidden;
  display: flex;
  flex-direction: column;
}
