.badge {
  display: inline-flex;
  align-items: center;
  gap: 6rpx;
  padding: 6rpx 12rpx;
  background: rgba(245, 200, 66, 0.12);
  border-radius: 999rpx;
  border: 1rpx solid rgba(245, 200, 66, 0.3);
  flex-shrink: 0;
}

.icon {
  font-size: 22rpx;
}

.value {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--gold);
  font-variant-numeric: tabular-nums;
}
