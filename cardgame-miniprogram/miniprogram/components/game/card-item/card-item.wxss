.card {
  width: 72rpx;
  height: 100rpx;
  border-radius: 8rpx;
  background: #fff;
  border: 1rpx solid rgba(0, 0, 0, 0.12);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: transform 0.15s ease;
}

.card.compact {
  width: 48rpx;
  height: 68rpx;
  border-radius: 6rpx;
}

.card.play-table {
  width: 44rpx;
  height: 62rpx;
  border-radius: 6rpx;
}

.card.play-table .rank {
  font-size: 16rpx;
}

.card.play-table .suit {
  font-size: 14rpx;
}

.card.play-table.back .back-pattern {
  width: 72%;
  height: 78%;
}

.card.play-back {
  width: 56rpx;
  height: 80rpx;
  border-radius: 8rpx;
}

.card.play-back .back-pattern {
  width: 72%;
  height: 80%;
}

.card.selected {
  transform: translateY(-12rpx);
  box-shadow: 0 4rpx 16rpx rgba(245, 200, 66, 0.65);
  z-index: 2;
}

.card.back {
  background: linear-gradient(135deg, #2a5ea8, #1a3d72);
  border-color: rgba(255, 255, 255, 0.2);
}

.back-pattern {
  width: 70%;
  height: 78%;
  border-radius: 4rpx;
  border: 2rpx dashed rgba(255, 255, 255, 0.35);
}

.rank {
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1;
}

.card.compact .rank {
  font-size: 18rpx;
}

.suit {
  font-size: 22rpx;
  line-height: 1;
}

.card.compact .suit {
  font-size: 16rpx;
}

.card.red .rank,
.card.red .suit {
  color: #d32f2f;
}

.card.black .rank,
.card.black .suit {
  color: #212121;
}
