page {
  --bg-app: #0f1923;
  --bg-panel: #1a2634;
  --bg-panel-hover: #243447;
  --table-green: #1b5e3b;
  --gold: #f5c842;
  --accent: #ff9800;
  --text-1: #ffffff;
  --text-2: rgba(255, 255, 255, 0.72);
  --text-3: rgba(255, 255, 255, 0.45);
  --danger: #ef5350;
  --success: #66bb6a;
  --border: rgba(255, 255, 255, 0.08);
  --safe-top: env(safe-area-inset-top);
  --safe-right: env(safe-area-inset-right);
  --safe-bottom: env(safe-area-inset-bottom);
  --safe-left: env(safe-area-inset-left);
  /* page-meta 动态注入 --ui-scale / --gap-md / --vh-rpx */
  --gap-md: 12rpx;
  --gap-sm: 8rpx;
  --panel-radius: 12rpx;

  width: 100%;
  height: 100%;
  overflow: hidden;
  background: var(--bg-app);
  color: var(--text-1);
  font-size: 22rpx;
  box-sizing: border-box;
}

view,
text,
button {
  box-sizing: border-box;
}

.btn-primary {
  background: var(--accent);
  color: var(--text-1);
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 600;
  padding: 10rpx 20rpx;
  border: none;
}

.btn-primary::after {
  border: none;
}

.btn-ghost {
  background: transparent;
  color: var(--text-2);
  border: 1rpx solid var(--border);
  border-radius: 8rpx;
  font-size: 22rpx;
  padding: 10rpx 20rpx;
}

.btn-ghost::after {
  border: none;
}

.panel {
  background: var(--bg-panel);
  border-radius: var(--panel-radius);
  border: 1rpx solid var(--border);
}

.text-muted {
  color: var(--text-2);
}

.text-gold {
  color: var(--gold);
}

/* 全屏页：勿用 100vw/100vh，横屏真机会按竖屏视口缩放导致整体被压缩 */
.page-full {
  width: 100%;
  height: 100%;
  box-sizing: border-box;
  padding: var(--safe-top) var(--safe-right) var(--safe-bottom) var(--safe-left);
}

.stub-page {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  background: var(--bg-app);
  box-sizing: border-box;
  padding: var(--safe-top) var(--safe-right) var(--safe-bottom) var(--safe-left);
}

.stub-page .title {
  font-size: 32rpx;
}

.stub-page .hint {
  color: var(--text-2);
  font-size: 24rpx;
}

.sub-page {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
  padding: var(--safe-top) var(--safe-right) var(--safe-bottom) var(--safe-left);
  background: var(--bg-app);
  overflow: hidden;
}

.sub-body {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: var(--gap-md);
  overflow: hidden;
}

.sub-body .hint {
  color: var(--text-2);
  font-size: 22rpx;
}
