{
  "compilerOptions": {
    "target": "ES2017",
    "module": "CommonJS",
    "strict": true,
    "noImplicitAny": true,
    "moduleResolution": "node",
    "types": ["miniprogram-api-typings"],
    "lib": ["ES2018"],
    "skipLibCheck": true
  },
  "include": ["miniprogram/**/*.ts"],
  "exclude": ["node_modules"]
}
